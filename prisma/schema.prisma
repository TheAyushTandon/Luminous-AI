// This is your Prisma schema file
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Chat Sessions
model ChatSession {
  id        String   @id @default(uuid())
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  Message[]
  pinned    Boolean  @default(false)
  archived  Boolean  @default(false)
  
  @@index([createdAt])
  @@index([pinned])
  @@index([archived])
}

// Chat Messages
model Message {
  id        String      @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String      // 'user' or 'assistant'
  content   String
  images    String?     // JSON string array of base64 images
  model     String?
  tokens    Int?
  createdAt DateTime    @default(now())
  
  @@index([sessionId])
  @@index([createdAt])
}

// Documents
model Document {
  id          String   @id @default(uuid())
  filename    String
  filepath    String
  mimetype    String
  size        Int
  status      String   @default("processing") // processing, ready, failed
  chunks      Chunk[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([status])
  @@index([createdAt])
}

// Document Chunks (for RAG)
model Chunk {
  id         String   @id @default(uuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content    String
  embedding  String?  // JSON string of vector
  pageNumber Int?
  metadata   String?  // JSON string
  createdAt  DateTime @default(now())
  
  @@index([documentId])
}

// Code Projects
model CodeProject {
  id          String      @id @default(uuid())
  name        String
  description String?
  path        String
  language    String
  files       CodeFile[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  @@index([createdAt])
}

// Code Files
model CodeFile {
  id          String      @id @default(uuid())
  projectId   String
  project     CodeProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  filename    String
  filepath    String
  content     String
  language    String
  analysis    String?     // JSON string of analysis results
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  @@index([projectId])
}

// Audio Files
model AudioFile {
  id             String   @id @default(uuid())
  filename       String
  filepath       String
  duration       Float?
  status         String   @default("processing") // processing, transcribed, failed
  transcription  String?
  speakers       String?  // JSON string of speaker diarization
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  @@index([status])
  @@index([createdAt])
}

// Model Configurations
model ModelConfig {
  id          String   @id @default(uuid())
  name        String   @unique
  type        String   // chat, code, embedding
  provider    String   // ollama, local, etc
  modelName   String
  parameters  String?  // JSON string
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([type])
  @@index([isActive])
}

// System Settings
model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  type      String   // string, number, boolean, json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
